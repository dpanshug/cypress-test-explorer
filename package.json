{
  "name": "cypress-test-explorer",
  "displayName": "Cypress Test Explorer",
  "publisher": "dpanshug",
  "repository": {
    "type": "git",
    "url": "https://github.com/dpanshug/cypress-test-explorer"
  },
  "description": "The ultimate tool for managing and running your Cypress tests directly within Visual Studio Code.",
  "version": "2.0.0",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.73.0"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [
    "workspaceContains:**/*.cy.ts",
    "workspaceContains:**/*.cy.js",
    "workspaceContains:**/*.cy.tsx",
    "workspaceContains:**/*.cy.jsx"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "test": [
        {
          "id": "cypressRunVariables",
          "name": "Cypress Test Explorer",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "cypressTestExplorer.setStartingFolder",
        "title": "Cypress: Set Root Folder"
      },
      {
        "command": "cypressTestExplorer.setProjectPath",
        "title": "Cypress: Set Project Path"
      },
      {
        "command": "cypressTestExplorer.updateRunVariables",
        "title": "Cypress: Update Run Variables"
      },
      {
        "command": "cypressTestExplorer.setCypressExecutable",
        "title": "Cypress: Set Executable Command"
      }
    ],
    "configuration": {
      "title": "Cypress Test Explorer",
      "properties": {
        "cypressTestExplorer.startingFolder": {
          "type": "string",
          "default": "",
          "description": "Specify the starting folder for Cypress tests (relative to workspace root)"
        },
        "cypressTestExplorer.cypressExecutable": {
          "type": "string",
          "default": "npx cypress",
          "description": "Specify the Cypress executable command (e.g., 'npx cypress' or path to Cypress binary)"
        },
        "cypressTestExplorer.configFilePath": {
          "type": "string",
          "default": "",
          "description": "Relative path to the Cypress configuration file (e.g., 'frontend/src/__tests__/cypress/cypress.config.ts')"
        },
        "cypressTestExplorer.projectPath": {
          "type": "string",
          "default": "",
          "description": "Relative path to the Cypress project directory (e.g., 'frontend/src/__tests__/cypress')"
        },
        "cypressTestExplorer.runVariables": {
          "type": "object",
          "default": {},
          "description": "Deprecated — migrated to environmentVariables automatically",
          "deprecationMessage": "Use cypressTestExplorer.environmentVariables and cypressTestExplorer.cypressEnv instead"
        },
        "cypressTestExplorer.environmentVariables": {
          "type": "object",
          "default": {},
          "description": "OS-level environment variables passed to the Cypress process (e.g., CY_MOCK=1)"
        },
        "cypressTestExplorer.cypressEnv": {
          "type": "object",
          "default": {},
          "description": "Cypress-specific env vars passed via --env flag, accessed with Cypress.env() (e.g., baseUrl=http://localhost)"
        },
        "cypressTestExplorer.browser": {
          "type": "string",
          "default": "",
          "enum": ["", "chrome", "firefox", "edge", "electron"],
          "enumDescriptions": [
            "Default (Cypress chooses)",
            "Google Chrome",
            "Mozilla Firefox",
            "Microsoft Edge",
            "Electron (built-in)"
          ],
          "description": "Browser to use when running Cypress tests"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "20.x",
    "@types/vscode": "^1.73.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.92.1",
    "webpack-cli": "^5.1.4"
  }
}
